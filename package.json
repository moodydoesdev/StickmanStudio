{
  "name": "youtube-explainer-studio",
  "version": "0.1.0",
  "description": "Stickman Studio — turn a topic into a finished stick-figure explainer video, powered by Claude Code skills.",
  "main": "./out/main/index.js",
  "author": "Stickman Studio",
  "//name": "Internal package id is kept stable so the dev userData path (config + installed runtime) isn't orphaned by the product rename. The shipped product name is set via electron-builder.yml productName.",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "build:mac": "electron-vite build && electron-builder --mac --config electron-builder.yml",
    "build:all": "electron-vite build && electron-builder -mw --config electron-builder.yml",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
